<?xml version="1.0" encoding="utf-8"?>
<!-- Launcher icon background: the app's dark surface with a faint vertical
     sheen so the tile doesn't read as a flat black square on AMOLED. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="108">
                <item android:offset="0" android:color="#FF17191D" />
                <item android:offset="1" android:color="#FF0B0C0E" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
